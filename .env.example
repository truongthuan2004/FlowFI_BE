# Copy this file to .env and replace every CHANGE_ME value.

FLOWFI_SHARED__Jwt__Issuer=FlowFi
FLOWFI_SHARED__Jwt__Audience=FlowFi.Clients
FLOWFI_SHARED__Jwt__SigningKey=CHANGE_ME_WITH_AT_LEAST_32_RANDOM_CHARACTERS
FLOWFI_SHARED__RabbitMq__Host=localhost
FLOWFI_SHARED__RabbitMq__Username=flowfi
FLOWFI_SHARED__RabbitMq__Password=CHANGE_ME

FLOWFI_AUTH__Urls=http://localhost:5101
FLOWFI_AUTH__ConnectionStrings__Default=Host=localhost;Port=6001;Database=FlowFi_AuthUser;Username=flowfi;Password=CHANGE_ME

FLOWFI_FINANCE__Urls=http://localhost:5102
FLOWFI_FINANCE__ConnectionStrings__Default=Host=localhost;Port=6002;Database=FlowFi_FinanceCore;Username=flowfi;Password=CHANGE_ME

FLOWFI_AI__Urls=http://localhost:5103
FLOWFI_AI__ConnectionStrings__Default=Host=localhost;Port=6000;Database=FlowFi_AIProcessing;Username=flowfi;Password=CHANGE_ME
FLOWFI_AI__AiProvider__Provider=GetNexAI
FLOWFI_AI__AiProvider__BaseUrl=https://getnexai.net/api/v1
FLOWFI_AI__AiProvider__ResponsesPath=/responses
FLOWFI_AI__AiProvider__Model=gpt-5.5
FLOWFI_AI__AiProvider__ApiKey=CHANGE_ME
FLOWFI_AI__AiProvider__TimeoutSeconds=30
FLOWFI_AI__AiProvider__ReasoningEffort=low
FLOWFI_AI__AiProvider__Verbosity=low

FLOWFI_ANALYTICS__Urls=http://localhost:5104
FLOWFI_ANALYTICS__ConnectionStrings__Default=Host=localhost;Port=6003;Database=FlowFi_Analytics;Username=flowfi;Password=CHANGE_ME

FLOWFI_NOTIFICATION__Urls=http://localhost:5105
FLOWFI_NOTIFICATION__ConnectionStrings__Default=Host=localhost;Port=6004;Database=FlowFi_Notification;Username=flowfi;Password=CHANGE_ME
FLOWFI_NOTIFICATION__Smtp__Host=smtp.gmail.com
FLOWFI_NOTIFICATION__Smtp__Port=587
FLOWFI_NOTIFICATION__Smtp__Username=CHANGE_ME
FLOWFI_NOTIFICATION__Smtp__Password=CHANGE_ME
FLOWFI_NOTIFICATION__Smtp__FromAddress=CHANGE_ME
FLOWFI_NOTIFICATION__Smtp__FromName="FlowFi Support"

FLOWFI_WEBSOCKET__Urls=http://localhost:5106
FLOWFI_GATEWAY__Urls=http://localhost:8080

POSTGRES_USER=flowfi
POSTGRES_PASSWORD=CHANGE_ME
AUTH_DB_NAME=FlowFi_AuthUser
FINANCE_DB_NAME=FlowFi_FinanceCore
AI_DB_NAME=FlowFi_AIProcessing
ANALYTICS_DB_NAME=FlowFi_Analytics
NOTIFICATION_DB_NAME=FlowFi_Notification
RABBITMQ_USER=flowfi
RABBITMQ_PASSWORD=CHANGE_ME
JWT_ISSUER=FlowFi
JWT_AUDIENCE=FlowFi.Clients
JWT_SIGNING_KEY=CHANGE_ME_WITH_AT_LEAST_32_RANDOM_CHARACTERS
AI_PROVIDER=GetNexAI
AI_PROVIDER_BASE_URL=https://getnexai.net/api/v1
AI_PROVIDER_RESPONSES_PATH=/responses
AI_PROVIDER_MODEL=gpt-5.5
AI_PROVIDER_API_KEY=CHANGE_ME
AI_PROVIDER_REASONING_EFFORT=low
AI_PROVIDER_VERBOSITY=low
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=CHANGE_ME
SMTP_PASSWORD=CHANGE_ME
SMTP_FROM_ADDRESS=CHANGE_ME
SMTP_FROM_NAME="FlowFi Support"
