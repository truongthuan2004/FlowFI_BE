{
  "Urls": "http://localhost:8080",
  "Jwt": {
    "Issuer": "FlowFi",
    "Audience": "FlowFi.Clients",
    "SigningKey": "CHANGE_ME_USE_AT_LEAST_32_CHARS_FOR_DEV"
  },
  "ServiceCatalog": {
    "Services": [
      {
        "Name": "auth",
        "PublicPath": "/auth",
        "BaseUrl": "http://auth-service:8080",
        "HealthPath": "/health"
      },
      {
        "Name": "finance",
        "PublicPath": "/finance",
        "BaseUrl": "http://finance-service:8080",
        "HealthPath": "/health"
      },
      {
        "Name": "ai",
        "PublicPath": "/ai",
        "BaseUrl": "http://ai-service:8080",
        "HealthPath": "/health"
      },
      {
        "Name": "analytics",
        "PublicPath": "/analytics",
        "BaseUrl": "http://analytics-service:8080",
        "HealthPath": "/health"
      },
      {
        "Name": "notifications",
        "PublicPath": "/notifications",
        "BaseUrl": "http://notification-service:8080",
        "HealthPath": "/health"
      },
      {
        "Name": "ws",
        "PublicPath": "/ws",
        "BaseUrl": "http://websocket-gateway:8080",
        "HealthPath": "/health"
      }
    ]
  },
  "ReverseProxy": {
    "Routes": {
      "docs-auth": {
        "ClusterId": "auth",
        "Match": {
          "Path": "/docs/auth/{**catch-all}"
        },
        "Transforms": [
          {
            "PathRemovePrefix": "/docs/auth"
          }
        ]
      },
      "docs-finance": {
        "ClusterId": "finance",
        "Match": {
          "Path": "/docs/finance/{**catch-all}"
        },
        "Transforms": [
          {
            "PathRemovePrefix": "/docs/finance"
          }
        ]
      },
      "docs-ai": {
        "ClusterId": "ai",
        "Match": {
          "Path": "/docs/ai/{**catch-all}"
        },
        "Transforms": [
          {
            "PathRemovePrefix": "/docs/ai"
          }
        ]
      },
      "docs-analytics": {
        "ClusterId": "analytics",
        "Match": {
          "Path": "/docs/analytics/{**catch-all}"
        },
        "Transforms": [
          {
            "PathRemovePrefix": "/docs/analytics"
          }
        ]
      },
      "docs-notifications": {
        "ClusterId": "notifications",
        "Match": {
          "Path": "/docs/notifications/{**catch-all}"
        },
        "Transforms": [
          {
            "PathRemovePrefix": "/docs/notifications"
          }
        ]
      },
      "auth": {
        "ClusterId": "auth",
        "Match": {
          "Path": "/auth/{**catch-all}"
        },
        "Transforms": [
          {
            "PathRemovePrefix": "/auth"
          }
        ]
      },
      "finance": {
        "ClusterId": "finance",
        "Match": {
          "Path": "/finance/{**catch-all}"
        },
        "Transforms": [
          {
            "PathRemovePrefix": "/finance"
          }
        ]
      },
      "ai": {
        "ClusterId": "ai",
        "Match": {
          "Path": "/ai/{**catch-all}"
        },
        "Transforms": [
          {
            "PathRemovePrefix": "/ai"
          }
        ]
      },
      "analytics": {
        "ClusterId": "analytics",
        "Match": {
          "Path": "/analytics/{**catch-all}"
        },
        "Transforms": [
          {
            "PathRemovePrefix": "/analytics"
          }
        ]
      },
      "notifications": {
        "ClusterId": "notifications",
        "Match": {
          "Path": "/notifications/{**catch-all}"
        },
        "Transforms": [
          {
            "PathRemovePrefix": "/notifications"
          }
        ]
      },
      "ws": {
        "ClusterId": "ws",
        "Match": {
          "Path": "/ws/{**catch-all}"
        },
        "Transforms": [
          {
            "PathRemovePrefix": "/ws"
          }
        ]
      }
    },
    "Clusters": {
      "auth": {
        "Destinations": {
          "default": {
            "Address": "http://auth-service:8080/"
          }
        }
      },
      "finance": {
        "Destinations": {
          "default": {
            "Address": "http://finance-service:8080/"
          }
        }
      },
      "ai": {
        "Destinations": {
          "default": {
            "Address": "http://ai-service:8080/"
          }
        }
      },
      "analytics": {
        "Destinations": {
          "default": {
            "Address": "http://analytics-service:8080/"
          }
        }
      },
      "notifications": {
        "Destinations": {
          "default": {
            "Address": "http://notification-service:8080/"
          }
        }
      },
      "ws": {
        "Destinations": {
          "default": {
            "Address": "http://websocket-gateway:8080/"
          }
        }
      }
    }
  }
}
